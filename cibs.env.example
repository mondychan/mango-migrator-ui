# Mango SOAP credentials/config used by the app runtime
CIBS_ENV=prod
CIBS_BASE_URL_TEST=https://test.cibs.cz
CIBS_BASE_URL_PROD=https://is.cibs.cz
CIBS_VERIFY_TLS=true
CIBS_CT=
CIBS_USERNAME=
CIBS_PASSWORD=

# ISPAdmin REST API source (required for sync)
ISPADMIN_API_BASE_URL=
ISPADMIN_API_TOKEN=
ISPADMIN_VERIFY_TLS=true
ISPADMIN_API_TIMEOUT_SEC=120

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_DISABLE_WEB_PREVIEW=true
TELEGRAM_API_TIMEOUT_SEC=20

# Optional runtime tuning
MANGO_KEEPALIVE_TIMEOUT_SEC=90
MANGO_SCHEDULER_POLL_SEC=15
